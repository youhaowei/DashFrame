{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "lib": ["dom", "dom.iterable", "esnext"],
    "isolatedModules": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "incremental": true,
    "noEmit": true
  },
  "include": ["**/*.ts", "**/*.tsx", "src/routeTree.gen.ts"],
  "exclude": ["node_modules", "dist", ".output"]
}
