{
  "name": "@dashframe/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "dashframe": "src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./app": {
      "bun": "./src/app.ts",
      "default": "./src/app.ts"
    },
    "./functions": {
      "bun": "./src/functions.ts",
      "default": "./src/functions.ts"
    }
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "check": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "@dashframe/assistant": "workspace:*",
    "@dashframe/connector-notion": "workspace:*",
    "@dashframe/engine": "workspace:*",
    "@dashframe/engine-server": "workspace:*",
    "@dashframe/server-core": "workspace:*",
    "@dashframe/types": "workspace:*",
    "@hono/node-server": "^1.19.12",
    "@hono/node-ws": "^1.3.0",
    "@wystack/db": "workspace:*",
    "@wystack/secret-vault": "workspace:*",
    "@wystack/server": "workspace:*",
    "hono": "^4.12.9",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@dashframe/eslint-config": "workspace:*",
    "@types/bun": "^1.2.0",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.28.0",
    "typescript": "5.7.2",
    "vitest": "^4.1.6"
  }
}
