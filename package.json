{
  "name": "dashframe",
  "version": "0.2.0-alpha.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*",
    "libs/stdui/packages/*",
    "libs/wystack/packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @dashframe/desktop dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck",
    "check": "turbo check",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": "prettier --write --loglevel=error"
  },
  "devDependencies": {
    "@dashframe/eslint-config": "workspace:*",
    "@types/node": "^22.10.1",
    "eslint": "^9.39.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.7.3",
    "typescript": "5.7.2"
  }
}
