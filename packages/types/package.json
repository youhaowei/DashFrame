{
  "name": "@dashframe/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Type definitions and contracts for DashFrame",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@dashframe/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^4.0.16",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  }
}
