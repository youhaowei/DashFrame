#!/bin/sh

# If the pusher was invoked with --git-dir or GIT_DIR set, git exports an
# absolute GIT_DIR into the hook environment. `git init`/`git fetch` honor
# GIT_DIR over -C, so the scratch-repo commands below would re-initialize
# THIS repo as bare (core.bare=true) and break every worktree operation.
# Capture the repo root FIRST while the env is still intact so that pushes
# launched with explicit repo context (--git-dir / absolute hooksPath) still
# resolve the correct working tree. Then cd + unset so scratch commands are safe.
repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE

# Verify pushed submodule pointers are reachable from their configured remotes.
# pre-push can push refs other than HEAD, so validate each local ref update from
# stdin instead of assuming the current checkout is the commit being pushed.

remote_name=${1:-origin}

zero_sha="0000000000000000000000000000000000000000"
tmp_updates=$(mktemp)
trap 'rm -f "$tmp_updates"' EXIT

cat >"$tmp_updates"

# Some older Git invocations provide no stdin for direct pushes; fall back to
# HEAD so the hook still protects the common `git push` path.
if [ ! -s "$tmp_updates" ]; then
  current_branch=$(git symbolic-ref --quiet --short HEAD || true)
  current_sha=$(git rev-parse --verify HEAD 2>/dev/null || true)
  if [ -n "$current_branch" ] && [ -n "$current_sha" ]; then
    printf "%s %s refs/heads/%s %s\n" "$current_branch" "$current_sha" "$current_branch" "$zero_sha" >"$tmp_updates"
  fi
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_sha" ] && continue
  [ "$local_sha" = "$zero_sha" ] && continue
  # Tags and other non-commit refs may not have a tree to inspect.
  git cat-file -e "$local_sha^{tree}" 2>/dev/null || continue

  # Enumerate submodules from .gitmodules so the guard works on fresh clones
  # where submodules have not been `git submodule update --init`'d yet.
  # `git submodule foreach` only iterates initialized ones and would silently
  # skip unreachable pointers in the bootstrap path.
  submodule_paths=$(git config --file .gitmodules --get-regexp 'submodule\..*\.path' 2>/dev/null | awk '{print $2}')
  for submodule_path in $submodule_paths; do
    [ -z "$submodule_path" ] && continue

    pointer_sha=$(git ls-tree "$local_sha" "$submodule_path" | awk '{print $3}')
    [ -z "$pointer_sha" ] && continue

    remote_url=$(git config --file .gitmodules "submodule.${submodule_path}.url")
    [ -z "$remote_url" ] && continue

    # Verify the gitlink SHA is reachable from the configured remote. We
    # fetch the object into a scratch dir so this works even when the
    # submodule isn't checked out locally — the previous foreach approach
    # would have silently skipped it on a fresh clone.
    scratch=$(mktemp -d)
    if ! git -C "$scratch" init --quiet --bare 2>/dev/null ||
       ! git -C "$scratch" fetch --quiet "$remote_url" "$pointer_sha" 2>/dev/null; then
      rm -rf "$scratch"
      echo ""
      echo "ERROR: Submodule '$submodule_path' pointer ($pointer_sha) is not reachable from $remote_url."
      echo "       Referenced by push update $local_ref ($local_sha) -> $remote_ref."
      echo ""
      echo "  Push the submodule commit first, for example:"
      echo "    cd $submodule_path && git push $remote_name HEAD"
      echo "    cd $(pwd)"
      echo ""
      exit 1
    fi
    rm -rf "$scratch"
  done
done <"$tmp_updates"
